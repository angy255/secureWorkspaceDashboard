# ─────────────────────────────────────────────────────────────
# Secure Workspace Dashboard — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── MySQL Database (TiDB Cloud) ───────────────────────────────
# Copy these values from your TiDB Cloud cluster → Connect panel
# Serverless clusters use port 4000 (not 3306) and require SSL (handled in db.ts)
DB_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=your_tidb_username
DB_PASSWORD=your_tidb_password
DB_NAME=workspace_db

# ── JWT ───────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_random_bytes_hex
JWT_REFRESH_SECRET=replace_with_different_64_random_bytes_hex

# ── CORS ──────────────────────────────────────────────────────
# The exact origin of your deployed frontend (no trailing slash)
FRONTEND_URL=https://your-vercel-app.vercel.app

# ── Email (production) ────────────────────────────────────────
# Leave unset in development — Ethereal test accounts are used automatically.
# In production, set these to send real email via your SMTP provider.
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
